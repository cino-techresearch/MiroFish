# LLM API configuration (any OpenAI SDK-compatible endpoint)
# Point this at your internal OpenAI-compatible server (e.g. a local codex-gateway).
# Include the /v1 suffix in the base URL.
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=http://127.0.0.1:39281/v1
LLM_MODEL_NAME=gpt-5.5

# ===== ZEP Memory Graph Configuration =====
# The free monthly quota is sufficient for basic usage: https://app.getzep.com/
ZEP_API_KEY=your_zep_api_key_here

# ===== Boosted LLM Configuration (OASIS simulation) =====
# The simulation scripts read these directly. Point them at the same internal server.
LLM_BOOST_API_KEY=your_api_key_here
LLM_BOOST_BASE_URL=http://127.0.0.1:39281/v1
LLM_BOOST_MODEL_NAME=gpt-5.5